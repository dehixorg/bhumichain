# ─── Fabric Mode ──────────────────────────────────────────────────────────────
# Set to "mock" for local dev/demo — all chaincode calls return pre-scripted responses
# Set to "real" when Fabric network is running (requires crypto material below)
FABRIC_MODE=mock

# ─── Fabric Network (real mode only) ─────────────────────────────────────────
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_TLS_ROOT_CERT=../../blockchain/network/crypto-config/peerOrganizations/revenue.maharashtra.gov.in/peers/peer0.revenue.maharashtra.gov.in/tls/ca.crt
FABRIC_CERT_PATH=../../blockchain/network/crypto-config/peerOrganizations/revenue.maharashtra.gov.in/users/Admin@revenue.maharashtra.gov.in/msp/signcerts/cert.pem
FABRIC_KEY_PATH=../../blockchain/network/crypto-config/peerOrganizations/revenue.maharashtra.gov.in/users/Admin@revenue.maharashtra.gov.in/msp/keystore/
FABRIC_MSP_ID=RevenueMSP
FABRIC_CHANNEL=state-channel-mh
FABRIC_NATIONAL_CHANNEL=national-channel

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=bhumichain-dev-secret-change-in-prod
JWT_EXPIRY=8h

# ─── Oracle Services ──────────────────────────────────────────────────────────
ORACLE_SERVICE_URL=http://localhost:8001
ORACLE_MODE=mock

# ─── AI Services ─────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8002
BHUMI_GPT_URL=http://localhost:8003

# ─── IPFS ─────────────────────────────────────────────────────────────────────
IPFS_GATEWAY=http://localhost:5001
IPFS_MODE=mock

# ─── WebSocket ────────────────────────────────────────────────────────────────
WS_PORT=4001

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
