# ─── Fabric ───────────────────────────────────────────────────────────────────
# "mock" → chaincode calls return scripted responses (use during Sprint 0–9)
# "real" → connects to live Fabric network on Azure VM (Sprint 10 onwards)
FABRIC_MODE=mock

FABRIC_PEER_ENDPOINT=<azure-vm-ip>:7051
FABRIC_CHANNEL=land-registry
FABRIC_MSP_ID=RevenueDeptMSP
FABRIC_PEER_TLS_CERT=./crypto/peer-tls-ca.crt
FABRIC_ADMIN_CERT=./crypto/admin-cert.pem
FABRIC_ADMIN_KEY=./crypto/admin-key.pem

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=change-this-before-demo-min-32-chars
JWT_EXPIRY=8h
AADHAAR_SALT=bhumichain-aadhaar-salt-change-this

# ─── Frontend (for CORS) ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://bhumichain.azurestaticapps.net

# ─── Claude API (REAL) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram Bot (REAL — create via @BotFather) ──────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAF...
TELEGRAM_MOCK=false
# Set TELEGRAM_MOCK=true during local dev if you don't want real messages

# ─── AWS DynamoDB (REAL — free tier) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
DYNAMO_TABLE_NOTIFICATIONS=bhumichain-notifications
DYNAMO_TABLE_TOKENS=bhumichain-tokens
DYNAMO_TABLE_EC_CACHE=bhumichain-ec-cache
DYNAMO_TABLE_ANALYTICS=bhumichain-analytics

# ─── IPFS / Pinata (REAL — free tier 1GB) ────────────────────────────────────
PINATA_API_KEY=...
PINATA_SECRET=...
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ─── Email — Mailhog in dev (REAL dev tool) ───────────────────────────────────
EMAIL_MOCK=true
MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025
EMAIL_FROM=noreply@bhumichain.in
# Production:
# EMAIL_MOCK=false
# SENDGRID_API_KEY=SG....

# ─── SMS — mocked for POC ─────────────────────────────────────────────────────
SMS_MOCK=true
# Production: MSG91_AUTH_KEY=...

# ─── AI Services (internal URLs) ──────────────────────────────────────────────
RECORD_SCAN_URL=http://localhost:8010
COPARCENARY_URL=http://localhost:8011
NYAYA_URL=http://localhost:8012
SETTLE_URL=http://localhost:8013
# Azure Container Apps production:
# RECORD_SCAN_URL=https://record-scan.azurecontainerapps.io
# COPARCENARY_URL=https://coparcenary-mapper.azurecontainerapps.io
# NYAYA_URL=https://nyaya-ai.azurecontainerapps.io
# SETTLE_URL=https://bhumi-settle.azurecontainerapps.io

# ─── Oracle Service ───────────────────────────────────────────────────────────
ORACLE_URL=http://localhost:8001
AADHAAR_MOCK=true
# AADHAAR_MOCK=true → OTP always "123456", demo personas pre-loaded
CRS_MOCK=true
UPI_MOCK=true
NEFT_MOCK=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
