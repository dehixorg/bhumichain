# Set to "mock" for demo — returns pre-scripted Satbara extraction
RECORD_SCAN_MODE=mock

PORT=8010

# Azure Document Intelligence (swap in when credits available)
AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=your-key-here
AZURE_DOC_INTEL_MODEL=prebuilt-document

# IPFS for document storage
IPFS_GATEWAY=http://localhost:5001
IPFS_MODE=mock

# API Gateway (to create DLPI after officer approval)
API_GATEWAY_URL=http://localhost:4000
