# AI Services Environment Configuration

# ─── Global ───────────────────────────────────────────────────────────────────
PORT=8002
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── BhumiGPT ─────────────────────────────────────────────────────────────────
# Anthropic Claude API Key for Marathi legal advisory
CLAUDE_API_KEY=your_claude_api_key_here
BHUMI_GPT_PORT=8012

# ─── RecordScan AI ────────────────────────────────────────────────────────────
# Azure Document Intelligence endpoint and key
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your_azure_key_here

# ─── FraudSense & Valuation ───────────────────────────────────────────────────
# Azure ML endpoints (optional for MVP demo)
VALUATION_ORACLE_ENDPOINT=https://your-valuation-ml.azure.com/
VALUATION_ORACLE_KEY=your_valuation_key

# ─── APIs ─────────────────────────────────────────────────────────────────────
# URL of the API Gateway to verify auth tokens or callback
API_GATEWAY_URL=http://localhost:4000
