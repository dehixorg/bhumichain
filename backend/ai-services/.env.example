# Shared across all 4 AI services
# Copy to each service directory as .env

# ─── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Service modes ────────────────────────────────────────────────────────────
RECORD_SCAN_MODE=claude       # claude | mock
NYAYA_MODE=claude             # claude | mock
COPARCENARY_MODE=real         # always real — pure Python, no LLM
SETTLE_MODE=real              # always real — pure Python, no LLM

# ─── AWS DynamoDB (for NyayaAI token tracking) ────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
DYNAMO_TABLE_TOKENS=bhumichain-tokens

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── API Gateway callback URL ─────────────────────────────────────────────────
API_GATEWAY_URL=http://localhost:4000

# ─── Service ports ────────────────────────────────────────────────────────────
PORT_RECORD_SCAN=8010
PORT_COPARCENARY=8011
PORT_NYAYA=8012
PORT_SETTLE=8013
