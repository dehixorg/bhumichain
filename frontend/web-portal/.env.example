# Environment Variables for BhumiChain Frontend Web Portal
# Copy this file to .env.local for local development

# API Gateway URL (Render deployment or local)
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:5000

# Map Tiles Configuration (e.g., SVAMITVA tiles or OpenStreetMap)
NEXT_PUBLIC_MAP_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Optional: Disable some map layers during dev
# NEXT_PUBLIC_DISABLE_CENSUS_LAYER=false
