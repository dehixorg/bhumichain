# BhumiChain Frontend — Environment Variables
# Copy to .env.local for local development

# ─── API Gateway ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
# Production:
# NEXT_PUBLIC_API_URL=https://api.bhumichain.in
# NEXT_PUBLIC_WS_URL=wss://api.bhumichain.in/ws

# ─── Fabric mode (shown in UI status bar) ─────────────────────────────────────
NEXT_PUBLIC_FABRIC_MODE=mock
# Set to "real" when Sprint 10 is done

# ─── Map (Dadri Tehsil, Gautam Buddha Nagar centre) ──────────────────────────
NEXT_PUBLIC_MAP_CENTER_LAT=28.5706
NEXT_PUBLIC_MAP_CENTER_LNG=77.5413
NEXT_PUBLIC_MAP_ZOOM=12
NEXT_PUBLIC_MAP_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
